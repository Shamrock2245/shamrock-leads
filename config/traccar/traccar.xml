<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE properties SYSTEM 'http://java.sun.com/dtd/properties.dtd'>
<!--
  Shamrock Bail Bonds — Traccar Server Configuration
  Mounted via Docker: ./config/traccar/traccar.xml:/opt/traccar/conf/traccar.xml:ro
  After editing, restart: docker compose restart traccar
-->
<properties>

  <!-- ── Database (H2 embedded — zero-config, persists to Docker volume) ── -->
  <entry key='database.driver'>org.h2.Driver</entry>
  <entry key='database.url'>jdbc:h2:/opt/traccar/data/database</entry>
  <entry key='database.user'>sa</entry>
  <entry key='database.password'></entry>

  <!-- ── Web Server ───────────────────────────────────────────────────── -->
  <entry key='web.enable'>true</entry>
  <entry key='web.port'>8082</entry>
  <entry key='web.address'>0.0.0.0</entry>
  <entry key='web.path'>/opt/traccar/web</entry>

  <!-- ── Geocoder (reverse geocoding for human-readable addresses) ─────── -->
  <entry key='geocoder.enable'>true</entry>
  <entry key='geocoder.type'>nominatim</entry>
  <!-- Nominatim is free; for production consider Google Maps geocoder -->
  <!-- <entry key='geocoder.type'>google</entry> -->
  <!-- <entry key='geocoder.key'>YOUR_GOOGLE_MAPS_KEY</entry> -->

  <!-- ── Device Protocols (GPS tracker ports) ─────────────────────────── -->
  <!-- OsmAnd (Android/iOS Traccar Client app — primary defendant tracking) -->
  <entry key='osmand.port'>5055</entry>
  <!-- GPS103/TK103 (cheap vehicle trackers) -->
  <entry key='gps103.port'>5001</entry>
  <entry key='tk103.port'>5002</entry>
  <!-- H02 (personal/ankle trackers) -->
  <entry key='h02.port'>5013</entry>
  <!-- GT06 / Concox (OBD2 vehicle trackers) -->
  <entry key='gt06.port'>5023</entry>
  <!-- Teltonika (professional fleet/asset trackers) -->
  <entry key='teltonika.port'>5027</entry>
  <!-- T55 / NMEA (legacy hardware) -->
  <entry key='t55.port'>5005</entry>
  <!-- Queclink GV series -->
  <entry key='queclink.port'>5009</entry>
  <!-- Meitrack (personal + vehicle trackers) -->
  <entry key='meitrack.port'>5020</entry>

  <!-- ── Filtering (reduce GPS noise) ─────────────────────────────────── -->
  <entry key='filter.enable'>true</entry>
  <entry key='filter.zero'>true</entry>
  <entry key='filter.invalid'>true</entry>
  <entry key='filter.accuracy'>100</entry>
  <entry key='filter.maxSpeed'>250</entry>
  <!-- Minimum distance between stored points (meters) -->
  <entry key='filter.distance'>50</entry>
  <!-- Minimum time between stored points (seconds) -->
  <entry key='filter.period'>60</entry>
  <entry key='filter.duplicate'>true</entry>

  <!-- ── Events / Notifications ────────────────────────────────────────── -->
  <entry key='event.enable'>true</entry>
  <!-- Geofence alerts -->
  <entry key='event.geofenceEnter'>true</entry>
  <entry key='event.geofenceExit'>true</entry>
  <!-- Device online/offline -->
  <entry key='event.deviceOnline'>true</entry>
  <entry key='event.deviceOffline'>true</entry>
  <!-- Motion events -->
  <entry key='event.deviceMoving'>true</entry>
  <entry key='event.deviceStopped'>true</entry>
  <!-- Overspeed (80mph = ~129km/h) -->
  <entry key='event.deviceOverspeed'>true</entry>
  <entry key='speedLimit'>129</entry>
  <!-- Handler flags -->
  <entry key='event.geofenceHandler'>true</entry>
  <entry key='event.overspeedHandler'>true</entry>
  <entry key='event.motionHandler'>true</entry>
  <entry key='event.ignitionHandler'>true</entry>

  <!-- ── Webhook Forward (push events to Shamrock dashboard) ──────────── -->
  <!-- Traccar forwards every position update + event to our Flask API     -->
  <!-- The dashboard container is reachable at shamrock-dashboard:5050     -->
  <entry key='forward.enable'>true</entry>
  <entry key='forward.url'>http://shamrock-dashboard:5050/api/traccar/webhook</entry>
  <entry key='forward.json'>true</entry>

  <!-- ── Storage ───────────────────────────────────────────────────────── -->
  <!-- Keep position history for 90 days -->
  <entry key='database.positionsHistoryDays'>90</entry>
  <entry key='database.eventsHistoryDays'>90</entry>
  <!-- Connection pool -->
  <entry key='database.pool.size'>5</entry>
  <entry key='database.pool.idleSize'>2</entry>

  <!-- ── Logging ───────────────────────────────────────────────────────── -->
  <entry key='logger.enable'>true</entry>
  <entry key='logger.level'>info</entry>
  <entry key='logger.file'>/opt/traccar/logs/tracker-server.log</entry>

  <!-- ── Timezone ──────────────────────────────────────────────────────── -->
  <entry key='time.zone'>America/New_York</entry>

  <!-- Public self-registration must stay off in production -->
  <entry key='web.registration'>false</entry>

</properties>
