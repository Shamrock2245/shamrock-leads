# ============================================
# ShamrockLeads — Docker Build Context Exclusions
# ============================================
# Reduces build context size and prevents secrets from leaking into images.

# Version control
.git
.gitignore

# Documentation (not needed in container)
docs/
BRAND.md
AGENTS.md
GEMINI.md
DATA_MODEL.md
ROADMAP.md
CONTRIBUTING.md
SECURITY.md
CHANGELOG.md
README.md

# Environment and secrets (mounted as volumes at runtime)
.env
*.env

# Credential files (mounted via volumes, not baked into image)
creds/

# Firebase/GCP secrets (mounted via config/ volume — but keep config/*.py!)
config/firebase*.json
config/google-services.json

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Agent skills and CI (not needed at runtime)
.agent/
.github/

# Logs and data (mounted as volumes)
logs/
*.log
*.heapsnapshot

# Nginx config (deployed separately on host)
nginx/

# Node modules (if any)
node_modules/

# Test files
tests/
*.test.py
