# ============================================================
# ShamrockLeads — Environment Configuration
# ============================================================
# Copy this to .env and fill in your values

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ShamrockBailDB

# --- Google Sheets (optional legacy writer) ---
GOOGLE_SPREADSHEET_ID=121z5R6Hpqur54GNPC8L26ccfDPLHTJc3_LU6G7IV_0E
GOOGLE_APPLICATION_CREDENTIALS=/app/creds/service-account-key.json

# --- OpenAI (lead scoring enrichment) ---
OPENAI_API_KEY=sk-...

# --- Slack Alerts ---
SLACK_WEBHOOK_ARRESTS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_LEADS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_ERRORS=https://hooks.slack.com/services/...

# --- Twilio (SMS outreach + court reminders) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
TWILIO_MESSAGING_SERVICE_SID=MG...
TWILIO_CAMPAIGN_SID=QE...

# --- Scraper Settings ---
SCRAPER_LOG_LEVEL=INFO
SCRAPER_MAX_CONCURRENT=3
SCRAPER_DEFAULT_INTERVAL_MINUTES=60

# --- Feature Flags ---
ENABLE_SHEETS_WRITER=true
ENABLE_MONGO_WRITER=true
ENABLE_SLACK_ALERTS=true
ENABLE_LEAD_SCORING=true

# --- County-Specific Credentials ---
HCSO_EMAIL=admin@shamrockbailbonds.biz
HCSO_PASSWORD=<your-hcso-password>

# --- Surety / Insurance Companies ---
# "osi" = O'Shaughnahill Surety & Insurance, Inc. (FL primary)
# "palmetto" = Palmetto Surety Corporation (FL, SC, NC, TN, TX, CT, LA, MS)
DEFAULT_SURETY=osi

# --- GAS Integration (legacy — being phased out) ---
GAS_WEB_APP_URL=https://script.google.com/macros/s/...

# --- Wix Webhook Auth ---
# Used to validate incoming Wix/Velo intake webhooks at /api/webhooks/wix-intake
# Falls back to GAS_API_KEY if not set. If neither is set, webhooks accept without auth.
WIX_WEBHOOK_SECRET=

# --- BlueBubbles (Self-Hosted iMessage — Multi-Server) ---
# Each office Mac runs its own BlueBubbles instance tied to a phone number.
# Suffix matches the last 4 digits of the cell number.

# Laptop 1: shamrockbailoffice@gmail.com → (239) 955-0178
BLUEBUBBLES_URL_0178=
BLUEBUBBLES_PASSWORD_0178=

# Laptop 2: brendanoneal99@gmail.com → (239) 955-0314
BLUEBUBBLES_URL_0314=
BLUEBUBBLES_PASSWORD_0314=

# Legacy single-server fallback (used if BLUEBUBBLES_URL_0178 is not set)
BLUEBUBBLES_URL=
BLUEBUBBLES_PASSWORD=

# --- SignNow (Direct API — replacing GAS relay) ---
SIGNNOW_API_TOKEN=your_signnow_bearer_token
SIGNNOW_API_BASE_URL=https://api.signnow.com
SIGNNOW_WEBHOOK_SECRET=your_webhook_signing_secret

# SignNow ROPC (Resource Owner Password Credentials) — fallback token flow
# Used by signnow_packet_service.py when SIGNNOW_API_TOKEN is not set.
# SIGNNOW_BASIC_AUTH is the Base64-encoded client_id:client_secret for the app.
SIGNNOW_BASIC_AUTH=M2I0ZGQ1MWUwYTA3NTU3ZTViMGU2YjQyNDE1NzU5ZGI6YjQ2MzNiZmU3ZjkwNDgzYWJjZjQ4MDE2MjBhZWRjNTk=
SIGNNOW_USERNAME=admin@shamrockbailbonds.biz
SIGNNOW_PASSWORD=

# --- SwipeSimple ---
SWIPESIMPLE_PAYMENT_LINK=https://swipesimple.com/links/lnk_b6bf996f4c57bb340a150e297e769abd

# --- Dashboard Auth ---
DASHBOARD_PIN=224545

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Gmail OAuth (Court Email Processor) ---
# Run: python scripts/get_gmail_token.py → authorize as admin@shamrockbailbonds.biz
GOOGLE_GMAIL_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=167447516147-is4h2qhcqa51qhlen97tpkcij33r5a1n.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# --- Google Calendar Integration ---
GOOGLE_CALENDAR_ID=admin@shamrockbailbonds.biz
# GOOGLE_APPLICATION_CREDENTIALS already set above — points to service account JSON

# --- Public URL (Branded Domain — Nginx Reverse Proxy) ---
# DASHBOARD_PUBLIC_URL: the public-facing URL of this VPS dashboard.
# Used for geo-tracking links (/g/<token>), BB webhook registration,
# and paperwork delivery links sent via iMessage.
#
# Production: https://leads.shamrockbailbonds.biz
# Setup:      bash scripts/setup_nginx_proxy.sh
# Docs:       docs/NGINX_PROXY_SETUP.md
DASHBOARD_PUBLIC_URL=https://leads.shamrockbailbonds.biz

# PORTAL_BASE_URL: the Wix indemnitor portal (for intake magic links).
# Defaults to the main website — only override if using a custom portal domain.
PORTAL_BASE_URL=https://shamrockbailbonds.biz

# --- BlueBubbles Enhancement Suite (Phase 2) ---
# BB_WEBHOOK_PUBLIC_URL: must match DASHBOARD_PUBLIC_URL.
# BlueBubbles servers POST incoming message events to:
#   ${BB_WEBHOOK_PUBLIC_URL}/api/webhooks/bluebubbles
BB_WEBHOOK_PUBLIC_URL=https://leads.shamrockbailbonds.biz

# Optional HMAC secret for verifying BB webhook payloads (leave blank to skip)
BB_WEBHOOK_SECRET=

# API key for iMac → VPS config sync (/api/bb/config endpoint)
# Default: shamrock-bb-sync-2245
BB_CONFIG_API_KEY=shamrock-bb-sync-2245

# Slack webhook for BB health alerts (can reuse SLACK_WEBHOOK_ERRORS)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#shamrock-alerts
