# ============================================================
# ShamrockLeads — Environment Configuration
# ============================================================
# Copy this to .env and fill in your values

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ShamrockBailDB

# --- Google Sheets (optional legacy writer) ---
GOOGLE_SPREADSHEET_ID=121z5R6Hpqur54GNPC8L26ccfDPLHTJc3_LU6G7IV_0E
GOOGLE_APPLICATION_CREDENTIALS=/app/creds/service-account-key.json

# --- OpenAI (lead scoring enrichment) ---
OPENAI_API_KEY=sk-...

# --- Slack Alerts ---
SLACK_WEBHOOK_ARRESTS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_LEADS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_ERRORS=https://hooks.slack.com/services/...

# --- Twilio (future: outreach) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# --- Scraper Settings ---
SCRAPER_LOG_LEVEL=INFO
SCRAPER_MAX_CONCURRENT=3
SCRAPER_DEFAULT_INTERVAL_MINUTES=60

# --- Feature Flags ---
ENABLE_SHEETS_WRITER=true
ENABLE_MONGO_WRITER=true
ENABLE_SLACK_ALERTS=true
ENABLE_LEAD_SCORING=true

# --- County-Specific Credentials ---
HCSO_EMAIL=admin@shamrockbailbonds.biz
HCSO_PASSWORD=<your-hcso-password>

# --- Surety / Insurance Companies ---
# "osi" = O'Shaughnahill Surety & Insurance, Inc. (FL primary)
# "palmetto" = Palmetto Surety Corporation (FL, SC, NC, TN, TX, CT, LA, MS)
DEFAULT_SURETY=osi

# --- GAS Integration ---
GAS_WEB_APP_URL=https://script.google.com/macros/s/...

# --- BlueBubbles (Self-Hosted iMessage — Multi-Server) ---
# Each office Mac runs its own BlueBubbles instance tied to a phone number.
# Suffix matches the last 4 digits of the cell number.

# Laptop 1: shamrockbailoffice@gmail.com → (239) 955-0178
BLUEBUBBLES_URL_0178=
BLUEBUBBLES_PASSWORD_0178=

# Laptop 2: admin@shamrockbailbonds.biz → (239) 955-0314
BLUEBUBBLES_URL_0314=
BLUEBUBBLES_PASSWORD_0314=

# Legacy single-server fallback (used if BLUEBUBBLES_URL_0178 is not set)
# BLUEBUBBLES_URL=
# BLUEBUBBLES_PASSWORD=
