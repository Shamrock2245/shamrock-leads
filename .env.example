# ============================================================
# ShamrockLeads — Environment Configuration
# ============================================================
# Copy this to .env and fill in your values

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ShamrockBailDB

# --- Google Sheets (optional legacy writer) ---
GOOGLE_SPREADSHEET_ID=121z5R6Hpqur54GNPC8L26ccfDPLHTJc3_LU6G7IV_0E
GOOGLE_APPLICATION_CREDENTIALS=/app/creds/service-account-key.json

# --- OpenAI (lead scoring enrichment) ---
OPENAI_API_KEY=sk-...

# --- Slack Alerts ---
# Create incoming webhooks at: https://api.slack.com/apps → Your App → Incoming Webhooks
# SLACK_WEBHOOK_ARRESTS  → #new-arrests-lee-county  (new arrests, re-arrest alerts from rearrest_detection)
# SLACK_WEBHOOK_LEADS    → #new-cases               (lead scoring, hot leads, SignNow complete, payment received, docket updates, speed-to-contact)
# SLACK_WEBHOOK_ERRORS   → #signing-errors          (scraper errors, BB health alerts, escalation alerts, forfeitures)
SLACK_WEBHOOK_ARRESTS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_LEADS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_ERRORS=https://hooks.slack.com/services/...

# --- Twilio (SMS outreach + court reminders) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
TWILIO_MESSAGING_SERVICE_SID=MG...
TWILIO_CAMPAIGN_SID=QE...

# --- Scraper Settings ---
SCRAPER_LOG_LEVEL=INFO
SCRAPER_MAX_CONCURRENT=3
SCRAPER_DEFAULT_INTERVAL_MINUTES=60

# --- Feature Flags ---
ENABLE_SHEETS_WRITER=true
ENABLE_MONGO_WRITER=true
ENABLE_SLACK_ALERTS=true
ENABLE_LEAD_SCORING=true

# --- County-Specific Credentials ---
HCSO_EMAIL=admin@shamrockbailbonds.biz
HCSO_PASSWORD=<your-hcso-password>

# --- CAPTCHA Solving Service ---
# SolveCaptcha API key for reCAPTCHA v2 bypass (Hillsborough County)
# Sign up at: https://solvecaptcha.com → Dashboard → API Key
# Cost: ~$0.55 per 1,000 solves (~$2/month at 10-min intervals)
SOLVECAPTCHA_KEY=

# --- Surety / Insurance Companies ---
# "osi" = O'Shaughnahill Surety & Insurance, Inc. (FL primary)
# "palmetto" = Palmetto Surety Corporation (FL, SC, NC, TN, TX, CT, LA, MS)
DEFAULT_SURETY=osi

# --- GAS Integration (shared with portal + bail-school) ---
GAS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GAS_API_KEY=generate-long-random-shared-secret

# --- Wix Webhook Auth ---
# Used to validate incoming Wix/Velo intake webhooks at /api/webhooks/wix-intake
# Falls back to GAS_API_KEY if not set. REQUIRED in production (webhooks fail closed).
WIX_WEBHOOK_SECRET=generate-long-random-secret

# --- BlueBubbles (Self-Hosted iMessage — Multi-Server) ---
# Each office Mac runs its own BlueBubbles instance tied to a phone number.
# Suffix matches the last 4 digits of the cell number.

# Laptop 1: office line (last 4)
BLUEBUBBLES_URL_0178=https://your-bb-tunnel.example.com
BLUEBUBBLES_PASSWORD_0178=your-bluebubbles-password

# Laptop 2: second line
BLUEBUBBLES_URL_0314=
BLUEBUBBLES_PASSWORD_0314=

# Legacy single-server fallback (used if BLUEBUBBLES_URL_0178 is not set)
BLUEBUBBLES_URL=https://your-bb-tunnel.example.com
BLUEBUBBLES_PASSWORD=your-bluebubbles-password

# --- SignNow (Direct API — replacing GAS relay) ---
SIGNNOW_API_TOKEN=your_signnow_bearer_token
SIGNNOW_API_BASE_URL=https://api.signnow.com
SIGNNOW_WEBHOOK_SECRET=your_webhook_signing_secret

# SignNow ROPC (Resource Owner Password Credentials) — fallback token flow
# Used by signnow_packet_service.py when SIGNNOW_API_TOKEN is not set.
# SIGNNOW_BASIC_AUTH is the Base64-encoded client_id:client_secret for the app.
SIGNNOW_BASIC_AUTH=
SIGNNOW_USERNAME=
SIGNNOW_PASSWORD=

# --- SwipeSimple ---
SWIPESIMPLE_PAYMENT_LINK=https://swipesimple.com/links/YOUR_LINK_ID

# --- Dashboard Auth (required in production) ---
DASHBOARD_PIN=your-6-digit-pin
SECRET_KEY=generate-long-random-session-signing-key
ENV=production
REQUIRE_DASHBOARD_PIN=true

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Gmail OAuth (Court Email Processor) ---
# Run: python scripts/get_gmail_token.py → authorize as admin@shamrockbailbonds.biz
GOOGLE_GMAIL_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Calendar Integration ---
GOOGLE_CALENDAR_ID=admin@shamrockbailbonds.biz
# GOOGLE_APPLICATION_CREDENTIALS already set above — points to service account JSON

# --- Public URL (Branded Domain — Nginx Reverse Proxy) ---
# DASHBOARD_PUBLIC_URL: the public-facing URL of this VPS dashboard.
# Used for geo-tracking links (/g/<token>), BB webhook registration,
# and paperwork delivery links sent via iMessage.
#
# Production: https://shamrockbailbonds.biz
# Setup:      bash scripts/setup_nginx_proxy.sh
# Docs:       docs/NGINX_PROXY_SETUP.md
DASHBOARD_PUBLIC_URL=https://shamrockbailbonds.biz

# PORTAL_BASE_URL: the Wix indemnitor portal (for intake magic links).
# Defaults to the main website — only override if using a custom portal domain.
PORTAL_BASE_URL=https://shamrockbailbonds.biz

# --- BlueBubbles Enhancement Suite (Phase 2) ---
# BB_WEBHOOK_PUBLIC_URL: must match DASHBOARD_PUBLIC_URL.
# BlueBubbles servers POST incoming message events to:
#   ${BB_WEBHOOK_PUBLIC_URL}/api/webhooks/bluebubbles
BB_WEBHOOK_PUBLIC_URL=https://leads.shamrockbailbonds.biz

# Optional HMAC secret for verifying BB webhook payloads (leave blank to skip)
BB_WEBHOOK_SECRET=f44694bd92293fe5b27c4a68adaf6991911ba067fcb813926bd6653bcd556754

# API key for iMac → VPS config sync (/api/bb/config endpoint)
# Default: shamrock-bb-sync-2245
BB_CONFIG_API_KEY=shamrock-bb-sync-2245

# Firebase Admin SDK — BlueBubbles URL auto-sync via Firestore
# Files are written to /opt/shamrock-leads/config/ by GitHub Actions deploy
# Mounted into Docker container at /app/config/ (read-only)
# BlueBubbles writes its current tunnel URL to Firestore; we poll it every 5 min
FIREBASE_ADMINSDK_PATH=/app/config/firebase-adminsdk.json
FIREBASE_POLL_INTERVAL=300
FIREBASE_ENABLED=true

# DEPRECATED: SLACK_WEBHOOK_URL is superseded by the 3 specific webhooks above.
# Set this to the same URL as SLACK_WEBHOOK_ERRORS for legacy code path fallback.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_CHANNEL is no longer used (channel is determined by the webhook URL itself)
# SLACK_CHANNEL=#shamrock-alerts

# ============================================================
# v2.1 ADDITIONS — Gmail Discharge Monitor + GCal Sync
# ============================================================

# --- Gmail Discharge Monitor ---
# OAuth2 credentials for scanning Gmail for court discharge emails.
# Run: python3 dashboard/api/discharge_monitor.py --authorize
# See: docs/GMAIL_DISCHARGE_SETUP.md
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json
GMAIL_DISCHARGE_LABEL=discharge
GMAIL_DISCHARGE_DAYS_BACK=7

# --- Google Calendar Court Date Sync ---
# OAuth2 token for pushing court dates to Google Calendar.
# See: docs/GCAL_SYNC_SETUP.md
GCAL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GCAL_TOKEN_PATH=credentials/gcal_token.json
GCAL_CALENDAR_ID=admin@shamrockbailbonds.biz
GCAL_DAYS_AHEAD=30

# --- Court Reminder Auto-Scan ---
COURT_REMINDER_DAYS_AHEAD=7
COURT_REMINDER_SCHEDULE_DAYS=7,3,1

# --- POA Low-Stock Thresholds ---
POA_LOW_STOCK_THRESHOLD=5
POA_CRITICAL_STOCK_THRESHOLD=2

# ============================================================
# Traccar GPS Tracking Engine
# ============================================================
# Internal Docker hostname — Traccar container is named 'traccar'
# so Docker DNS resolves 'traccar' within the compose network.
TRACCAR_URL=http://traccar:8082
TRACCAR_EMAIL=admin@shamrockbailbonds.biz
TRACCAR_PASSWORD=shamrock-traccar-2245
# Long-lived API token (generated by setup_admin.sh — paste here after running it)
TRACCAR_TOKEN=
# External URL for the bond-tracker.html standalone dashboard
# (used when accessing the tracker from outside the VPS)
TRACCAR_EXTERNAL_URL=http://<YOUR_VPS_IP>:8082

# ============================================================
# CourtListener API (Free Law Project — Court Intelligence)
# ============================================================
# Free tier: 5,000 requests/day. Register at:
#   https://www.courtlistener.com/sign-in/
# Then generate a token at:
#   https://www.courtlistener.com/api/rest/v4/?format=api (click "Log in" → Token)
# Used by: dashboard/services/court_data_ingestor.py
#          dashboard/services/docket_monitor.py
# Without this key, CourtListener requests are unauthenticated (rate-limited to ~100/day).
COURTLISTENER_API_TOKEN=05820ccbc9989b9ae5490a0af760d69772ef07b8

# ============================================================
# Postiz — Self-Hosted Social Media Manager
# ============================================================
# Open-source alternative to Buffer/Ayrshare ($0/month, self-hosted)
# 30+ platforms: Twitter, LinkedIn, Facebook, Instagram, Threads, etc.
# Docker service runs on port 5200 externally.
# 
# After first startup:
#   1. Navigate to http://<VPS_IP>:5200
#   2. Create an admin account
#   3. Go to Settings → API Keys → Generate
#   4. Paste the key below
#   5. Connect your social channels via the Postiz UI
#
POSTIZ_API_KEY=
POSTIZ_URL=http://postiz:5000
POSTIZ_MAIN_URL=http://178.156.179.237:5200
POSTIZ_JWT_SECRET=shamrock-postiz-jwt-change-me-in-production
POSTIZ_DB_PASSWORD=shamrock_postiz_2026

# ============================================================
# Social OAuth — Platform Connections
# ============================================================
# These client credentials enable OAuth "Login with..." on the
# dashboard Social tab. Each platform requires a developer app:
#
# Google:   https://console.cloud.google.com → Credentials → OAuth 2.0
# Twitter:  https://developer.twitter.com → Apps → OAuth 2.0
# LinkedIn: https://www.linkedin.com/developers → App → Auth
# Meta:     https://developers.facebook.com → App → Facebook Login
#
# Redirect URIs (register these in each developer console):
#   Google:   https://leads.shamrockbailbonds.biz/api/social/oauth/google/callback
#   Twitter:  https://leads.shamrockbailbonds.biz/api/social/oauth/twitter/callback
#   LinkedIn: https://leads.shamrockbailbonds.biz/api/social/oauth/linkedin/callback
#   Meta:     https://leads.shamrockbailbonds.biz/api/social/oauth/meta/callback

# Google OAuth (GBP + YouTube) — can reuse the same GCP project as Gmail
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Twitter / X OAuth 2.0
TWITTER_OAUTH_CLIENT_ID=your-twitter-oauth-client-id
TWITTER_OAUTH_CLIENT_SECRET=your-twitter-oauth-client-secret

# LinkedIn OAuth 2.0
LINKEDIN_OAUTH_CLIENT_ID=your-linkedin-client-id
LINKEDIN_OAUTH_CLIENT_SECRET=your-linkedin-client-secret

# Meta (Facebook + Instagram) OAuth 2.0
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# OAuth redirect base URL (must match what's registered in developer consoles)
SOCIAL_OAUTH_REDIRECT_BASE=https://leads.shamrockbailbonds.biz
